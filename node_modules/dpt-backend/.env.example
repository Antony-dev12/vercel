# ════════════════════════════════════════════════════════════════
# Digital Presence Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it's already in .gitignore.
# ════════════════════════════════════════════════════════════════

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
# Free PostgreSQL options:
#   Render:   https://render.com/docs/databases     (free tier, same region as backend)
#   Supabase: https://supabase.com                  (free tier, generous limits)
#   Neon:     https://neon.tech                     (free tier, serverless)
DATABASE_URL=postgresql://user:password@localhost:5432/dpt_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string

# ── Token Encryption (AES-256-GCM) ───────────────────────────────────────────
# Used to encrypt OAuth access/refresh tokens stored in the database.
# Generate with: openssl rand -hex 32
# MUST be exactly 64 hex characters (32 bytes).
TOKEN_ENCRYPTION_KEY=change-this-to-a-64-char-hex-string-from-openssl-rand

# ── Session (for OAuth handshake only) ───────────────────────────────────────
# Can reuse JWT_SECRET value if you prefer
SESSION_SECRET=change-this-to-another-random-string

# ── Meta (Facebook + Instagram) ───────────────────────────────────────────────
# Setup steps:
#   1. Go to https://developers.facebook.com/apps/
#   2. Create App → Business type
#   3. Add products: "Facebook Login" + "Instagram Graph API"
#   4. App Settings → Basic → copy App ID and App Secret
#   5. Facebook Login → Settings → add Valid OAuth Redirect URI:
#      http://localhost:3001/auth/facebook/callback
#   6. For production: submit App Review for pages_read_engagement etc.
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# ── Google Business Profile ───────────────────────────────────────────────────
# Setup steps:
#   1. Go to https://console.cloud.google.com/
#   2. Create or select a project
#   3. APIs & Services → Enable:
#      - My Business Account Management API
#      - My Business Business Information API
#      - My Business Reviews API (for review response rate)
#   4. APIs & Services → Credentials → Create → OAuth 2.0 Client ID
#      Application type: Web application
#      Authorised redirect URI: http://localhost:3001/auth/google/callback
#   5. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Password Reset Email via Resend ───────────────────────────────────────────
# Activate steps:
#   1. npm install resend
#   2. Sign up at https://resend.com (free tier: 3,000 emails/month)
#   3. Verify your sending domain
#   4. Create API key and paste below
#   5. Uncomment the Resend block in src/routes/auth.js
# RESEND_API_KEY=re_your_key_here

# ── AI Recommendations (OPTIONAL) ────────────────────────────────────────────
# Activate steps:
#   1. npm install @anthropic-ai/sdk   (or: npm install openai)
#   2. Add your key below
#   3. Uncomment the import + getAIRecommendations call in src/routes/scores.js
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# ── Background Sync (OPTIONAL) ───────────────────────────────────────────────
# Activate steps:
#   1. npm install node-cron
#   2. Uncomment startSyncJob() in src/server.js
#   (No env var needed — runs on the server's internal timer)

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
